# =============================================================================
# YUKU JAPAN - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git (it's in .gitignore)
# =============================================================================

# =============================================================================
# REQUIRED: Supabase Configuration
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (for server-side operations)
# Mark as "Sensitive" in Vercel
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# OPTIONAL: Google APIs
# =============================================================================
# Get from: https://console.cloud.google.com/apis/credentials

GOOGLE_PLACES_API_KEY=your-google-places-api-key-here
ROUTING_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
GOOGLE_DIRECTIONS_API_KEY=your-google-directions-api-key-here

# =============================================================================
# OPTIONAL: Vertex AI (Gemini via service account)
# =============================================================================
# Create a service account with "Vertex AI User" role in GCP console,
# download the JSON key, and minify it to a single line for this value.
# Powers: intent extraction, day refinement, guide prose generation
# Without this, itineraries still work but skip AI refinement passes

GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# =============================================================================
# OPTIONAL: Mapbox Routing
# =============================================================================
# Get from: https://www.mapbox.com/

ROUTING_PROVIDER=mapbox
ROUTING_MAPBOX_ACCESS_TOKEN=your-mapbox-access-token-here
# Public token for client-side map rendering (same token, exposed to browser)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-access-token-here
# Optional custom style URL override. If unset, falls back to the default
# published style in src/lib/env.ts. Set this if the Mapbox account or
# style ID changes, so no code change / redeploy is needed.
# NEXT_PUBLIC_MAPBOX_STYLE_URL=mapbox://styles/your-account/your-style-id

# Google Places API (New) — used as fallback when Mapbox Search Box doesn't
# return a good result for custom itinerary locations. Triggered only on
# explicit user action; not called during normal typing.
GOOGLE_PLACES_API_KEY=your-google-places-key-here

# =============================================================================
# REQUIRED FOR PRODUCTION: Rate Limiting (Upstash Redis)
# =============================================================================
# Get from: https://upstash.com
#
# IMPORTANT: Without Redis, rate limiting uses in-memory storage which does NOT
# work correctly with multiple server instances (Vercel edge functions, multiple
# pods, etc.). This can lead to:
# - Inconsistent rate limiting across instances
# - Potential for abuse by spreading requests across instances
# - Memory leaks in long-running development servers
#
# For production deployments, Redis is REQUIRED for proper rate limiting.
# In development, in-memory fallback is acceptable for testing.

UPSTASH_REDIS_REST_URL=your-redis-url-here
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# =============================================================================
# OPTIONAL: Site Configuration
# =============================================================================

NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# =============================================================================
# OPTIONAL: Sanity CMS (for guide authoring)
# =============================================================================
# Get from: https://www.sanity.io/manage

NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2026-02-10
SANITY_API_WRITE_TOKEN=your-write-token
SANITY_REVALIDATE_SECRET=your-webhook-secret

# =============================================================================
# OPTIONAL: Feature Flags
# =============================================================================

# Use mock itinerary data (for development)
NEXT_PUBLIC_USE_MOCK_ITINERARY=false

# Enable/disable external API calls
ENABLE_GOOGLE_PLACES=true
ENABLE_MAPBOX=true

# Disable expensive API calls (for cost control)
CHEAP_MODE=false

# Disable strict env validation in production
VALIDATE_ENV=true

# =============================================================================
# Free launch promo gates. BOTH must be set together.
# =============================================================================
# FREE_FULL_ACCESS is the server-side gate; NEXT_PUBLIC_FREE_FULL_ACCESS is the client-side gate.
# Setting only one causes the UI and backend to disagree about whether the promo is active.
# Always update both in lockstep: when toggling the promo on or off, set both to the same value.

FREE_FULL_ACCESS=false
NEXT_PUBLIC_FREE_FULL_ACCESS=false

# =============================================================================
# OPTIONAL: Sentry Error Monitoring
# =============================================================================
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
# Without this, errors are only logged to console (no remote monitoring)

NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
SENTRY_DSN=your-sentry-dsn-here
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# =============================================================================
# OPTIONAL: OpenWeatherMap (weather forecasts in itinerary)
# =============================================================================
# Get from: https://openweathermap.org/appid (free tier: 1k calls/day, 5-day forecast)
# Without this, mock seasonal weather data is used instead.

OPENWEATHER_API_KEY=your-openweathermap-api-key-here

# =============================================================================
# OPTIONAL: NAVITIME Transit Routing (Japan)
# =============================================================================
# Get from: https://rapidapi.com/navitime/api/navitime-route-totalnavi
# Provides detailed Japanese transit directions (line colors, fares, gates)

NAVITIME_RAPIDAPI_KEY=your-navitime-rapidapi-key-here

# =============================================================================
# OPTIONAL: Server-side PDF generation
# =============================================================================
# HMAC secret for signing short-lived tokens that authorize the internal
# Chromium instance to fetch /print/trip/[id]/pdf via service-role Supabase.
# Generate with: openssl rand -hex 32
# If unset, /api/trips/[id]/pdf returns 503 and the UI falls back to
# browser-native window.print(). No action required for local dev.
PDF_TOKEN_SECRET=
