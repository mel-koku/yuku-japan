{
  "name": "yuku-japan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/seed-cache.mjs && NODE_OPTIONS='--dns-result-order=ipv4first --max-old-space-size=8192' next dev",
    "dev:fast": "NODE_OPTIONS='--dns-result-order=ipv4first --max-old-space-size=8192' next dev",
    "dev:debug": "NODE_OPTIONS='--dns-result-order=ipv4first --max-old-space-size=8192 --import ./scripts/exit-monitor.mjs' next dev",
    "seed-cache": "node scripts/seed-cache.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "a11y": "node .github/scripts/a11y-check.mjs",
    "seed:locations": "tsx scripts/seed-locations.ts",
    "seed:jnto": "tsx scripts/seed-jnto-locations.ts",
    "guidance:generate": "tsx scripts/generate-guidance.ts",
    "guidance:seed": "tsx scripts/seed-guidance.ts",
    "guidance:backfill": "tsx scripts/backfill-guidance-content.ts",
    "dq": "tsx scripts/data-quality/dq.ts",
    "dq:audit": "tsx scripts/data-quality/dq.ts audit",
    "dq:fix": "tsx scripts/data-quality/dq.ts fix",
    "dq:fix:dry": "tsx scripts/data-quality/dq.ts fix --dry-run",
    "dq:report": "tsx scripts/data-quality/dq.ts report",
    "dq:list": "tsx scripts/data-quality/dq.ts list",
    "dq:guidance": "tsx scripts/data-quality/dq.ts audit --rules=guidance",
    "audit:export": "tsx scripts/data-quality/export-audit-issues.ts",
    "audit:import": "tsx scripts/data-quality/import-audit-fixes.ts",
    "audit:import:dry": "tsx scripts/data-quality/import-audit-fixes.ts --dry-run",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:push": "supabase db push",
    "supabase:db:reset": "supabase db reset",
    "supabase:db:diff": "supabase db diff",
    "supabase:migration:new": "supabase migration new",
    "supabase:link": "supabase link",
    "analyze": "ANALYZE=true npm run build",
    "prepare": "husky"
  },
